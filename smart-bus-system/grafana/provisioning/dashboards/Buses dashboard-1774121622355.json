          "getPayload": "const formValues = {};\n\ncontext.panel.elements.forEach((element) => {\n  if (element.value) {\n    formValues[element.id] = element.value;\n  }\n});\n\nconst stopsSelectionForm = context.panel.elements.find((element) => element.id === 'selectStops');\n\nstops = Array.from(stopsSelectionForm.value)\nconst payload = {\n  \"id\": formValues.uniqueID,\n  \"capacity\": parseFloat(formValues.capacity),\n  \"route\": stops\n};\n\n\nreturn payload;",
