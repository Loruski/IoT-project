        "initial": {
          "code": "const fetchAndPopulateStops = async () => {\n  try {\n \n    const currentElement = context.panel.options.elements.find(el => el.id === \"selectStops\");\n\n\n    if (currentElement && currentElement.options && currentElement.options.length > 0) {\n      return;\n    }\n\n\n\n    const response = await fetch('http://localhost:5000/getStops');\n\n    if (!response.ok) {\n      throw new Error(`Errore HTTP: ${response.status}`);\n    }\n\n    const data = await response.json();\n\n    \n    const newOptions = data.map((item) => ({\n      label: item.name, \n      value: item.id    \n    }));\n\n    \n    const updatedElements = context.panel.options.elements.map((element) => {\n      if (element.id === \"selectStops\") {\n        return {\n          ...element,\n          options: newOptions\n        };\n      }\n      return element;\n    });\n\n    \n    context.panel.onOptionsChange({\n      ...context.panel.options,\n      elements: updatedElements\n    });\n\n  } catch (error) {\n    \n    console.error(\"Errore durante il recupero dei dati:\", error);\n    context.grafana.notifyError([\"Errore di caricamento\", \"Impossibile recuperare le fermate via GET\"]);\n  }\n};\n\n\nreturn fetchAndPopulateStops();",
