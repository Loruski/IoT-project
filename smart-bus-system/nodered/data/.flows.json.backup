    {
        "id": "195290f2764eb075",
        "type": "function",
        "z": "fedad3d5513a812d",
        "name": "extract id",
        "func": "let data = msg.payload;\n\n// 1. Forza la conversione in oggetto se non lo è già\nif (typeof data === 'string') {\n    try {\n        data = JSON.parse(data);\n    } catch (e) {\n        node.error(\"Errore nel parsing JSON: \" + e.message);\n        return null;\n    }\n}\n\nlet array = msg.topic.split(\"/\");\nlet stopId = array[1];   // \"Stop1\", \"Stop4\", ecc.\nlet sensorType = array[2]; // \"temp\", \"rain\", ecc.\n\n// 2. Controllo sicurezza per evitare 'undefined'\nif (data && data.hasOwnProperty('value')) {\n    // Prepariamo il payload per il nodo Join\n    msg.payload = {\n        [sensorType]: data.value,\n        timestamp: data.timestamp\n    };\n\n    // 3. AGGIUNGIAMO I TAG PER INFLUXDB\n    // Questo creerà una colonna \"bus_stop\" nel tuo database Influx\n    msg.tags = {\n        bus_stop: stopId\n    };\n\n    // Impostiamo il topic per il raggruppamento del nodo Join\n    msg.topic = stopId;\n\n    return msg;\n} else {\n    node.warn(\"Payload non contiene 'value': \" + JSON.stringify(data));\n    return null;\n}",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 620,
        "y": 620,
        "wires": [
            [
                "df6809d8e47f952a"
            ]
        ]
    },
